{
    "name": "ak-codehub/db-vault",
    "description": "DB Vault: an internal, self-contained DB access-broker panel (Horizon/Filament-style) that mounts inside any Laravel 12 app at a configurable domain/path, with its own auth, 2FA, SPA, and JSON API.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/ak-codehub/db-vault",
    "support": {
        "issues": "https://github.com/ak-codehub/db-vault/issues",
        "source": "https://github.com/ak-codehub/db-vault"
    },
    "keywords": ["laravel", "db-vault", "access-broker", "audit", "rbac"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/auth": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "aws/aws-sdk-php": "^3.0",
        "pragmarx/google2fa": "^8.0",
        "bacon/bacon-qr-code": "^3.0",
        "laravel/prompts": "^0.1.16 || ^0.3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "DbVault\\": "src/",
            "DbVault\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DbVault\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DbVault\\DbVaultServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
